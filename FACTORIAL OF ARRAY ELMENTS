import java.util.*;

public class Main {
    
    public static long fact(int n) {
        long f = 1;
        for(int i = 1; i <= n; i++) {
            f *= i;
        }
        return f;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        for(int i = 0; i < n; i++) {
            int num = sc.nextInt();
            System.out.print(fact(num) + " ");
        }
    }
}
